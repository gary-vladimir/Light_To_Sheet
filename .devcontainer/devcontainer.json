{
  "name": "Light to Sheet",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "ms-python.vscode-pylance"]
    }
  },
  "forwardPorts": [5000],
  "postCreateCommand": "pip install --no-cache-dir -r requirements.txt",
  "postStartCommand": "echo 'Run: python app.py  (web) or python main.py (CLI)'"
}
